// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= Authentication & Authorization =============

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  description String?
  permissions Permission[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id        String   @id @default(uuid())
  name      String   @unique
  description String?
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  department String?
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  active    Boolean  @default(true)
  mfaEnabled Boolean @default(false)
  mfaSecret String?
  alerts    AlertAssignment[]
  comments  AlertComment[]
  preferences UserPreferences?
  apiKeys   ApiKey[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPreferences {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAlerts     Boolean  @default(true)
  emailSeverity   String[] @default(["critical", "high"])
  slackAlerts     Boolean  @default(false)
  slackWebhook    String?
  dailySummary    Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ApiKey {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  key       String   @unique
  lastUsedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============= Core Alert System =============

model Alert {
  id              String   @id @default(uuid())
  alertCode       String   @unique @default(cuid())
  source          String   // wazuh, deep-security, firewall, etc.
  name            String
  description     String?
  severity        String   // low, medium, high, critical
  status          String   @default("new") // new, in_progress, escalated, closed, archived
  verdict         String   @default("unclassified") // true_positive, false_positive, benign, suspicious, unclassified
  priorityScore   Int      @default(0)

  // Timing
  alertTime       DateTime
  eventTime       DateTime

  // Asset & User Context
  assetId         String?
  asset           Asset?   @relation(fields: [assetId], references: [id])
  username        String?

  // Network Info
  sourceIp        String?
  destinationIp   String?
  destinationPort Int?
  protocol        String?

  // MITRE Mapping
  mitreTactic     String?
  mitreTechnique  String?
  ruleId          String?

  // Raw Data
  rawEvent        Json?

  // Assignments & Escalation
  assignedTo      AlertAssignment[]
  escalatedAt     DateTime?
  escalatedBy     String?
  escalationReason String?
  escalationL2Notes String?

  // Workflow
  comments        AlertComment[]
  timeline        AlertTimeline[]
  tickets         Ticket[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([source])
  @@index([severity])
  @@index([status])
  @@index([alertTime])
}

model AlertAssignment {
  id        String   @id @default(uuid())
  alertId   String
  alert     Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  assignedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([alertId, userId])
  @@index([userId])
}

model AlertComment {
  id        String   @id @default(uuid())
  alertId   String
  alert     Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([alertId])
  @@index([userId])
}

model AlertTimeline {
  id        String   @id @default(uuid())
  alertId   String
  alert     Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  action    String   // assigned, commented, escalated, closed, archived
  details   String?
  createdAt DateTime @default(now())

  @@index([alertId])
}

// ============= Assets & Criticality =============

model Asset {
  id          String   @id @default(uuid())
  hostname    String   @unique
  ip          String?  @unique
  macAddress  String?
  criticality String   @default("medium") // low, medium, high, critical
  assetType   String?  // server, workstation, network, etc.
  owner       String?
  location    String?
  alerts      Alert[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([hostname])
}

// ============= Tickets & Incidents =============

model Ticket {
  id            String   @id @default(uuid())
  ticketCode    String   @unique @default(cuid())
  alertId       String?
  alert         Alert?   @relation(fields: [alertId], references: [id])
  incidentId    String?
  incident      Incident? @relation(fields: [incidentId], references: [id])
  title         String
  description   String?
  severity      String   // low, medium, high, critical
  status        String   @default("open") // open, assigned, in_progress, waiting_user, waiting_it, resolved, closed, reopened
  assignedTeam  String?
  ownerId       String?
  dueTime       DateTime?
  resolutionNotes String?
  businessImpact String?
  recommendedAction String?

  comments      TicketComment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([severity])
}

model Incident {
  id          String   @id @default(uuid())
  incidentCode String  @unique @default(cuid())
  title       String
  description String?
  severity    String   // low, medium, high, critical
  status      String   @default("open")
  owner       String?
  tickets     Ticket[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content   String
  author    String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ============= SLA & Compliance =============

model SLAPolicy {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  severity    String   // applies to: low, medium, high, critical
  responseTime Int     // minutes
  resolutionTime Int   // hours
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============= Integrations =============

model Integration {
  id          String   @id @default(uuid())
  name        String   @unique
  type        String   // wazuh, deep-security, firewall, email, etc.
  config      Json     // API key, endpoint, etc.
  status      String   @default("inactive") // active, inactive, error
  lastSyncAt  DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
}

// ============= IOC & Watchlists =============

model IOC {
  id          String   @id @default(uuid())
  type        String   // ip, domain, hash, email, url
  value       String   @unique
  severity    String   // low, medium, high, critical
  source      String?  // threat intel source
  active      Boolean  @default(true)
  lastSeen    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([value])
}

model Watchlist {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  items       String[] // IPs, domains, hashes
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============= Audit & Compliance =============

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String   // login, alert_viewed, status_changed, etc.
  resource  String?  // alert_id, user_id, etc.
  changes   Json?    // what changed
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============= Notification Rules =============

model NotificationRule {
  id        String   @id @default(uuid())
  name      String
  trigger   String   // critical_alert, sla_breach, escalated, etc.
  channels  String[] // email, teams, telegram, slack
  recipients String[] // user emails or team names
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============= Notifications =============

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  title     String
  message   String
  type      String   // alert.created, alert.escalated, ticket.created, etc.
  relatedId String?  // alert_id, ticket_id, incident_id, etc.
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
